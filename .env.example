# =============================================
# ABR Technologies — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# =============================================

# Supabase (get from supabase.com → your project → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Resend (get from resend.com → API Keys)
RESEND_API_KEY=re_your_key_here

# Email settings
CONTACT_EMAIL_TO=enquiry@abrtechnologies.in
CONTACT_EMAIL_FROM=website@abrtechnologies.in

# WhatsApp Business API (get from Meta for Developers)
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-phone-number-id

# General
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://abrtechnologies.in
